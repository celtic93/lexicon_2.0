<h1><%= @word.text %></h1>

<div class="word-show__actions">
  <%= link_to "Back to words", words_path %>
</div>

<ul class="meanings-list">
    <% @word.meanings.each do |meaning| %>
        <li class="meanings-list__item">
            <div class="meaning-card <%= meaning_card_status_class(meaning.status) %>">
                <p class="meaning-card__text">
                    <%= meaning.text %>
                </p>

                <p class="meaning-card__status">
                    Status: <strong><%= meaning.status %></strong>
                </p>

                <% if status_actionable?(meaning.status) %>
                    <div class="meaning-card__actions">
                        <%= button_to "Duplicate",
                            meaning_path(meaning),
                            method: :patch,
                            params: { meaning: { status: "duplicate" } },
                            class: "button button--secondary" %>

                        <%= button_to "Add to Anki",
                            anki_cards_path,
                            method: :post,
                            params: { meaning_id: meaning.id },
                            class: "button button--primary" %>
                    </div>
                <% end %>
            </div>
        </li>
    <% end %>
</ul>
